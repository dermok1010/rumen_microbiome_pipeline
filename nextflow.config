process {
  executor = 'slurm'
  cpus = 8
  memory = '24 GB'
  time = '8h'
  errorStrategy = 'retry'
  maxRetries = 2

  clusterOptions = '--output=slurm-%j.out --error=slurm-%j.err'
  
}

apptainer {
  enabled = true
  autoMounts = true
  runOptions = '--bind /home/dermot.kelly/Dermot_primary/microbiome_data/'
}

profiles {
  apptainer {
    process.container = "$baseDir/rumen_microbiome_pipeline.sif"
  }
}

params {
  base_dir    = "$PWD"
  manifest    = "$base_dir/manifest_files/test_run1_manifest.tsv"
  classifier  = "$base_dir/classifier/silva-138-99-341F-806R-classifier.qza"
  output_dir  = "$base_dir/test_run1_outputs"
  results_dir = "$base_dir/test_run1_results"
  prefix      = "run2"

  trim_left_f = 17
  trim_left_r = 21
  trunc_len_f = 230
  trunc_len_r = 200
}
